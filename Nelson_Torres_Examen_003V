        "# =========================================================\n",
        "# PetMarket - Sistema de administración de catálogo y stock\n",
        "# =========================================================\n",
        "\n",
        "# ---------- FUNCIÓN: leer opción del menú ----------\n",
        "def leer_opcion():\n",
        "    while True:\n",
        "        try:\n",
        "            opcion = int(input(\"Ingrese opción: \"))\n",
        "            if 1 <= opcion <= 6:\n",
        "                return opcion\n",
        "            else:\n",
        "                print(\"Debe seleccionar una opción válida\")\n",
        "        except ValueError:\n",
        "            print(\"Debe seleccionar una opción válida\")\n",
        "\n",
        "\n",
        "# ---------- OPCIÓN 1: unidades por categoría ----------\n",
        "def unidades_categoria(categoria, productos, stock):\n",
        "    total = 0\n",
        "    for codigo in productos:\n",
        "        if productos[codigo][1].lower() == categoria.lower():\n",
        "            total += stock[codigo][1]\n",
        "    print(f\"El total de unidades disponibles es: {total}\")\n",
        "\n",
        "\n",
        "# ---------- OPCIÓN 2: búsqueda por rango de precio ----------\n",
        "def busqueda_precio(p_min, p_max, productos, stock):\n",
        "    resultados = []\n",
        "    for codigo in stock:\n",
        "        precio = stock[codigo][0]\n",
        "        unidades = stock[codigo][1]\n",
        "        if p_min <= precio <= p_max and unidades != 0:\n",
        "            nombre = productos[codigo][0]\n",
        "            resultados.append(f\"{nombre}--{codigo}\")\n",
        "\n",
        "    if len(resultados) == 0:\n",
        "        print(\"No hay productos en ese rango de precios.\")\n",
        "    else:\n",
        "        resultados.sort()\n",
        "        print(f\"Los productos encontrados son: {resultados}\")\n",
        "\n",
        "\n",
        "# ---------- FUNCIÓN AUXILIAR: buscar código ----------\n",
        "def buscar_codigo(codigo, productos):\n",
        "    codigo = codigo.upper()\n",
        "    for c in productos:\n",
        "        if c.upper() == codigo:\n",
        "            return True\n",
        "    return False\n",
        "\n",
        "\n",
        "# Función auxiliar interna: devuelve la clave real (respetando el case original)\n",
        "def _obtener_clave_real(codigo, productos):\n",
        "    codigo = codigo.upper()\n",
        "    for c in productos:\n",
        "        if c.upper() == codigo:\n",
        "            return c\n",
        "    return None\n",
        "\n",
        "\n",
        "# ---------- OPCIÓN 3: actualizar precio ----------\n",
        "def actualizar_precio(codigo, nuevo_precio, productos, stock):\n",
        "    if buscar_codigo(codigo, productos):\n",
        "        clave_real = _obtener_clave_real(codigo, productos)\n",
        "        stock[clave_real][0] = nuevo_precio\n",
        "        return True\n",
        "    return False\n",
        "\n",
        "\n",
        "# ---------- OPCIÓN 4: funciones de validación individuales ----------\n",
        "def validar_codigo(codigo, productos):\n",
        "    if codigo.strip() == \"\":\n",
        "        return False\n",
        "    if buscar_codigo(codigo, productos):\n",
        "        return False\n",
        "    return True\n",
        "\n",
        "def validar_nombre(nombre):\n",
        "    return nombre.strip() != \"\"\n",
        "\n",
        "def validar_categoria(categoria):\n",
        "    return categoria.strip() != \"\"\n",
        "\n",
        "def validar_marca(marca):\n",
        "    return marca.strip() != \"\"\n",
        "\n",
        "def validar_peso(peso):\n",
        "    try:\n",
        "        peso = float(peso)\n",
        "        return peso > 0\n",
        "    except ValueError:\n",
        "        return False\n",
        "\n",
        "def validar_sn(valor):\n",
        "    return valor.lower() in (\"s\", \"n\")\n",
        "\n",
        "def validar_precio(precio):\n",
        "    try:\n",
        "        precio = int(precio)\n",
        "        return precio > 0\n",
        "    except ValueError:\n",
        "        return False\n",
        "\n",
        "def validar_unidades(unidades):\n",
        "    try:\n",
        "        unidades = int(unidades)\n",
        "        return unidades >= 0\n",
        "    except ValueError:\n",
        "        return False\n",
        "\n",
        "\n",
        "# ---------- OPCIÓN 4: agregar producto ----------\n",
        "def agregar_producto(codigo, nombre, categoria, marca, peso_kg,\n",
        "                       es_importado, es_para_cachorro, precio, unidades,\n",
        "                       productos, stock):\n",
        "    if buscar_codigo(codigo, productos):\n",
        "        return False\n",
        "    productos[codigo] = [nombre, categoria, marca, peso_kg,\n",
        "                           es_importado, es_para_cachorro]\n",
        "    stock[codigo] = [precio, unidades]\n",
        "    return True\n",
        "\n",
        "\n",
        "# ---------- OPCIÓN 5: eliminar producto ----------\n",
        "def eliminar_producto(codigo, productos, stock):\n",
        "    if buscar_codigo(codigo, productos):\n",
        "        clave_real = _obtener_clave_real(codigo, productos)\n",
        "        del productos[clave_real]\n",
        "        del stock[clave_real]\n",
        "        return True\n",
        "    return False\n",
        "\n",
        "\n",
        "# ---------- MENÚ ----------\n",
        "def mostrar_menu():\n",
        "    print(\"\\n========== MENÚ PRINCIPAL ==========\")\n",
        "    print(\"1. Unidades por categoría\")\n",
        "    print(\"2. Búsqueda de productos por rango de precio\")\n",
        "    print(\"3. Actualizar precio de producto\")\n",
        "    print(\"4. Agregar producto\")\n",
        "    print(\"5. Eliminar producto\")\n",
        "    print(\"6. Salir\")\n",
        "    print(\"=====================================\")\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# PROGRAMA PRINCIPAL\n",
        "# =========================================================\n",
        "def main():\n",
        "    # Diccionarios iniciales\n",
        "    productos = {\n",
        "        'M001': ['Alimento Premium', 'comida', 'DogPlus', 10, True, False],\n",
        "        'M002': ['Arena Aglomerante', 'higiene', 'CatClean', 8, False, False],\n",
        "        'M003': ['Snack Dental', 'snack', 'BiteJoy', 1, True, True],\n",
        "        'M004': ['Shampoo Suave', 'higiene', 'PetCare', 0.5, False, True],\n",
        "        'M005': ['Correa Nylon', 'accesorio','WalkPro', 0.3, True, False],\n",
        "        'M006': ['Cama Mediana', 'accesorio','CozyPet', 2, False, False],\n",
        "    }\n",
        "\n",
        "    stock = {\n",
        "        'M001': [32990, 12],\n",
        "        'M002': [9990, 0],\n",
        "        'M003': [5490, 25],\n",
        "        'M004': [7990, 5],\n",
        "        'M005': [11990, 7],\n",
        "        'M006': [24990, 3],\n",
        "    }\n",
        "\n",
        "    while True:\n",
        "        mostrar_menu()\n",
        "        opcion = leer_opcion()\n",
        "\n",
        "        # ---------- OPCIÓN 1 ----------\n",
        "        if opcion == 1:\n",
        "            categoria = input(\"Ingrese categoría a consultar: \")\n",
        "            unidades_categoria(categoria, productos, stock)\n",
        "\n",
        "        # ---------- OPCIÓN 2 ----------\n",
        "        elif opcion == 2:\n",
        "            # Validación de enteros con manejo de excepciones (en el main)\n",
        "            while True:\n",
        "                try:\n",
        "                    p_min = int(input(\"Ingrese precio mínimo: \"))\n",
        "                    p_max = int(input(\"Ingrese precio máximo: \"))\n",
        "                    if p_min < 0 or p_max < 0:\n",
        "                        print(\"Los precios deben ser mayores o iguales a cero\")\n",
        "                        continue\n",
        "                    if p_min > p_max:\n",
        "                        print(\"El precio mínimo debe ser menor o igual al máximo\")\n",
        "                        continue\n",
        "                    break\n",
        "                except ValueError:\n",
        "                    print(\"Debe ingresar valores enteros\")\n",
        "            busqueda_precio(p_min, p_max, productos, stock)\n",
        "\n",
        "        # ---------- OPCIÓN 3 ----------\n",
        "        elif opcion == 3:\n",
        "            continuar = \"s\"\n",
        "            while continuar == \"s\":\n",
        "                codigo = input(\"Ingrese código del producto: \")\n",
        "\n",
        "                # Validar nuevo precio como entero positivo\n",
        "                while True:\n",
        "                    try:\n",
        "                        nuevo_precio = int(input(\"Ingrese nuevo precio: \"))\n",
        "                        if nuevo_precio > 0:\n",
        "                            break\n",
        "                        else:\n",
        "                            print(\"El precio debe ser un entero positivo\")\n",
        "                    except ValueError:\n",
        "                        print(\"Debe ingresar un valor entero\")\n",
        "\n",
        "                if actualizar_precio(codigo, nuevo_precio, productos, stock):\n",
        "                    print(\"Precio actualizado\")\n",
        "                else:\n",
        "                    print(\"El código no existe\")\n",
        "\n",
        "                # Preguntar si desea actualizar otro\n",
        "                while True:\n",
        "                    continuar = input(\"¿Desea actualizar otro precio (s/n)?: \").lower()\n",
        "                    if continuar in (\"s\", \"n\"):\n",
        "                        break\n",
        "                    print(\"Debe ingresar 's' o 'n'\")\n",
        "\n",
        "        # ---------- OPCIÓN 4 ----------\n",
        "        elif opcion == 4:\n",
        "            codigo = input(\"Ingrese código del producto: \")\n",
        "            nombre = input(\"Ingrese nombre: \")\n",
        "            categoria = input(\"Ingrese categoría: \")\n",
        "            marca = input(\"Ingrese marca: \")\n",
        "            peso = input(\"Ingrese peso (kg): \")\n",
        "            imp = input(\"¿Es importado? (s/n): \")\n",
        "            cach = input(\"¿Es para cachorro? (s/n): \")\n",
        "            precio = input(\"Ingrese precio: \")\n",
        "            unidades = input(\"Ingrese unidades: \")\n",
        "\n",
        "            # Validaciones (los mensajes van en el main)\n",
        "            if not validar_codigo(codigo, productos):\n",
        "                print(\"El código es inválido o ya existe\")\n",
        "            elif not validar_nombre(nombre):\n",
        "                print(\"El nombre es inválido\")\n",
        "            elif not validar_categoria(categoria):\n",
        "                print(\"La categoría es inválida\")\n",
        "            elif not validar_marca(marca):\n",
        "                print(\"La marca es inválida\")\n",
        "            elif not validar_peso(peso):\n",
        "                print(\"El peso debe ser un número mayor que cero\")\n",
        "            elif not validar_sn(imp):\n",
        "                print(\"El campo 'es importado' debe ser 's' o 'n'\")\n",
        "            elif not validar_sn(cach):\n",
        "                print(\"El campo 'es para cachorro' debe ser 's' o 'n'\")\n",
        "            elif not validar_precio(precio):\n",
        "                print(\"El precio debe ser un entero mayor que cero\")\n",
        "            elif not validar_unidades(unidades):\n",
        "                print(\"Las unidades deben ser un entero mayor o igual a cero\")\n",
        "            else:\n",
        "                # Conversión de datos ya validados\n",
        "                peso_kg = float(peso)\n",
        "                es_importado = (imp.lower() == \"s\")\n",
        "                es_para_cachorro = (cach.lower() == \"s\")\n",
        "                precio = int(precio)\n",
        "                unidades = int(unidades)\n",
        "\n",
        "                if agregar_producto(codigo, nombre, categoria, marca, peso_kg,\n",
        "                                    es_importado, es_para_cachorro,\n",
        "                                    precio, unidades, productos, stock):\n",
        "                    print(\"Producto agregado\")\n",
        "                else:\n",
